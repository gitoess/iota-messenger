# =============================================================================
# IOTA Messenger — Minimal-Preset (Phase 1)
# Eigenständiges Projekt — kein Boss/Handoff/Remote-Signer
# =============================================================================

PRODUCT_ID=iota-messenger
MESSENGER_EDITION=iota-messenger
UI_VARIANT=messenger
ROLE=messenger
ROLE_ID=14
SIMPLE_MODE=true
DEPLOYMENT_PROFILE=consumer
TRANSPORT_PROFILE=iota-anchored

ENABLE_UI=true
API_PORT=3342
API_BIND_HOST=127.0.0.1
API_KILL_PREVIOUS_INSTANCE=true

# Wallet lokal auf dem Gerät
SIGNER=sdk

# Shared Mailbox — IOTA Messenger Testnet-Starter (siehe product/testnet-starter.json)
USE_MAILBOX=true
MAILBOX_ID=0x32b65223c4bef0d932d40b65af4a1a77b0877495d450beb98fc05303714137f6
PACKAGE_ID=0x06e099c095548b36cfb6eb3373ad1aa73e72f83f6e53c51854df719e7836dc88
RPC_URL=https://api.testnet.iota.cafe
NEXT_PUBLIC_DIRECT_IOTA_RPC_URL=https://api.testnet.iota.cafe
NEXT_PUBLIC_PRODUCT_ID=iota-messenger
NEXT_PUBLIC_IOTA_MESSENGER_TESTNET_PACKAGE_ID=0x06e099c095548b36cfb6eb3373ad1aa73e72f83f6e53c51854df719e7836dc88
NEXT_PUBLIC_IOTA_MESSENGER_TESTNET_MAILBOX_ID=0x32b65223c4bef0d932d40b65af4a1a77b0877495d450beb98fc05303714137f6

ENABLE_PLAINTEXT_CHANNEL=false
ENABLE_PURGE=true
ENABLE_REPLAY_PROTECTION=true

# Kein Boss-Relay nötig — Direkt-RPC Standard
# REMOTE_SIGNER_URL=
# BOSS_ADDRESS=
# API_AUTH_TOKEN=
